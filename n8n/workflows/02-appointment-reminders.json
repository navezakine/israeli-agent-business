        "headerParameters": {
          "parameters": [
            { "name": "x-cron-secret", "value": "REPLACE_WITH_CRON_SECRET" }
          ]
        },
        "options": {}
      },
      "id": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb",
      "name": "Trigger reminders",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    }

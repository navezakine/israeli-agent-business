# ─────────────────────────────────────────────────────────────
# agent-brain — environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude API) ── you already have this key
ANTHROPIC_API_KEY=sk-ant-...
# Model: claude-haiku-4-5 is cheapest (testing); claude-sonnet-4-6 is better Hebrew (production)
CLAUDE_MODEL=claude-haiku-4-5

# Twilio (WhatsApp) ── you already have a Twilio account
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Sandbox number for testing, or your production number later

# Google Calendar (service account) ── set up in Step 3
GOOGLE_SERVICE_ACCOUNT_EMAIL=agent@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Agent Mail (agentmail.dev) ── set up in Step 0
AGENTMAIL_API_KEY=...
AGENT_EMAIL_FROM=dana@agentmail.dev

# OpenAI ── powers voice-note transcription (Whisper). Leave blank to disable:
# without it the bot politely asks voice-note senders to type instead.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Service config
PORT=3000
NODE_ENV=development
CLIENTS_DIR=../../clients   # Path to the clients/ folder, relative to agent-brain

# HITL config ── your personal WhatsApp number for approvals
HITL_APPROVER_WHATSAPP=+972XXXXXXXXX

# Shared secret protecting /cron endpoints (n8n sends it as the x-cron-secret header)
CRON_SECRET=change-me

# Where operator error alerts go (defaults to HITL_APPROVER_WHATSAPP if unset)
ALERT_WHATSAPP=

# Supabase ── durable history, leads, appointments, toggles (replaces SQLite).
# Locally these are read from the repo-root .env.supabase; set them here (or in
# Railway variables) for production. Get them from Supabase → Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # SECRET — bypasses row-level security

# Meta (Instagram + Facebook Messenger) for the /webhook/meta route.
# META_VERIFY_TOKEN: any random string you choose; enter the same value in the Meta
# app webhook setup. Per-clinic page/IG access tokens live in Supabase (channel_accounts).
META_VERIFY_TOKEN=change-me-random-string
META_GRAPH_VERSION=v23.0

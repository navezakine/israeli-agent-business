# ─────────────────────────────────────────────────────────────
# agent-brain — environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude API) ── you already have this key
ANTHROPIC_API_KEY=sk-ant-...
# Model: claude-haiku-4-5 is cheapest (testing); claude-sonnet-4-6 is better Hebrew (production)
CLAUDE_MODEL=claude-haiku-4-5

# Twilio (WhatsApp) ── you already have a Twilio account
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Sandbox number for testing, or your production number later

# Google Calendar (service account) ── set up in Step 3
GOOGLE_SERVICE_ACCOUNT_EMAIL=agent@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Agent Mail (agentmail.dev) ── set up in Step 0
AGENTMAIL_API_KEY=...
AGENT_EMAIL_FROM=dana@agentmail.dev

# Service config
PORT=3000
NODE_ENV=development
CLIENTS_DIR=../../clients   # Path to the clients/ folder, relative to agent-brain

# HITL config ── your personal WhatsApp number for approvals
HITL_APPROVER_WHATSAPP=+972XXXXXXXXX

# Shared secret protecting /cron endpoints (n8n sends it as the x-cron-secret header)
CRON_SECRET=change-me

# Optional: Redis for production conversation history (leave blank to use local SQLite)
REDIS_URL=
